{
  "name": "deepfilternet3-noise-filter",
  "version": "1.2.1",
  "description": "Custom audio processor with DeepFilterNet3 noise filtering integrated with LiveKit client",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "module": "dist/index.esm.js",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.esm.js",
      "require": "./dist/index.js"
    }
  },
  "files": [
    "dist/index.js",
    "dist/index.esm.js",
    "dist/index.d.ts",
    "README.md",
    "LICENSE-APACHE",
    "LICENSE-MIT"
  ],
  "scripts": {
    "build": "rollup -c && node --input-type=module -e \"import { unlinkSync } from 'fs'; unlinkSync('dist/DeepFilterWorklet.js');\"",
    "type-check": "tsc --noEmit"
  },
  "keywords": [
    "livekit",
    "audio",
    "noise-filter",
    "deepfilternet3",
    "webrtc"
  ],
  "license": "(Apache-2.0 OR MIT)",
  "peerDependencies": {
    "livekit-client": "^2.0.0"
  },
  "devDependencies": {
    "@rollup/plugin-commonjs": "^28.0.0",
    "@rollup/plugin-node-resolve": "^16.0.0",
    "@rollup/plugin-typescript": "^12.0.0",
    "@rollup/plugin-url": "^8.0.2",
    "@types/audioworklet": "^0.0.87",
    "livekit-client": "^2.0.0",
    "rollup": "^4.0.0",
    "rollup-plugin-dts": "^6.0.0",
    "rollup-plugin-string": "^3.0.0",
    "typescript": "^5.0.0"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jubbio/noise-suppression.git"
  }
}
